{
  "name": "fluid-client",
  "version": "0.1.0",
  "description": "Fluid client library for gasless Stellar transactions with Web Worker support",
  "main": "dist/index.js",
  "browser": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:worker": "tsc src/workers/signingWorker.ts --outDir dist --target ES2020 --module ESNext --lib ES2020,WebWorker,DOM",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "demo": "python -m http.server 8080",
    "test:performance": "open demo.html"
  },
  "keywords": [
    "stellar",
    "fee-bump",
    "gasless",
    "web-worker",
    "wasm",
    "cryptography",
    "performance"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@stellar/stellar-sdk": "^11.3.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "files": [
    "dist/**/*",
    "src/**/*",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./worker": {
      "import": "./dist/workers/signingWorker.js",
      "types": "./dist/workers/signingWorker.d.ts"
    }
  }
}
